{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "regions": ["sin1"],
  "functions": {
    "api/auth/discord.js": {
      "maxDuration": 15
    },
    "api/callback.js": {
      "maxDuration": 15
    },
    "api/session.js": {
      "maxDuration": 15
    },
    "api/logout.js": {
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
