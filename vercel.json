{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "regions": ["sin1"],
  "functions": {
    "api/index.js": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/api/auth/discord", "destination": "/api/index?__valaxPath=auth/discord" },
    { "source": "/api/callback", "destination": "/api/index?__valaxPath=callback" },
    { "source": "/api/session", "destination": "/api/index?__valaxPath=session" },
    { "source": "/api/logout", "destination": "/api/index?__valaxPath=logout" },
    { "source": "/api/onboarding/status", "destination": "/api/index?__valaxPath=onboarding/status" },
    { "source": "/api/onboarding/bot", "destination": "/api/index?__valaxPath=onboarding/bot" },
    { "source": "/api/dashboard", "destination": "/api/index?__valaxPath=dashboard" },
    { "source": "/api/dashboard/test", "destination": "/api/index?__valaxPath=dashboard/test" },
    { "source": "/api/server", "destination": "/api/index?__valaxPath=server" },
    { "source": "/api/server/messages", "destination": "/api/index?__valaxPath=server/messages" },
    { "source": "/api/server/members", "destination": "/api/index?__valaxPath=server/members" },
    { "source": "/api/server/expressions", "destination": "/api/index?__valaxPath=server/expressions" },
    { "source": "/api/server/expression-library", "destination": "/api/index?__valaxPath=server/expression-library" },
    { "source": "/api/server/dm", "destination": "/api/index?__valaxPath=server/dm" },
    { "source": "/api/server/dm-recent", "destination": "/api/index?__valaxPath=server/dm-recent" },
    { "source": "/api/server/dm-campaigns", "destination": "/api/index?__valaxPath=server/dm-campaigns" },
    { "source": "/api/server/notifications", "destination": "/api/index?__valaxPath=server/notifications" },
    { "source": "/api/health", "destination": "/api/index?__valaxPath=health" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
