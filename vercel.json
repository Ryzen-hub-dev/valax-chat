{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "regions": ["sin1"],
  "functions": {
    "api/auth/discord.js": {
      "maxDuration": 15
    },
    "api/callback.js": {
      "maxDuration": 15
    },
    "api/session.js": {
      "maxDuration": 15
    },
    "api/logout.js": {
      "maxDuration": 15
    },
    "api/onboarding/status.js": {
      "maxDuration": 15
    },
    "api/onboarding/bot.js": {
      "maxDuration": 15
    },
    "api/dashboard.js": {
      "maxDuration": 15
    },
    "api/dashboard/test.js": {
      "maxDuration": 15
    },
    "api/server.js": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/api/server/messages", "destination": "/api/server?__valaxRoute=messages" },
    { "source": "/api/server/members", "destination": "/api/server?__valaxRoute=members" },
    { "source": "/api/server/dm", "destination": "/api/server?__valaxRoute=dm" },
    { "source": "/api/server/dm-campaigns", "destination": "/api/server?__valaxRoute=dm-campaigns" },
    { "source": "/api/server/notifications", "destination": "/api/server?__valaxRoute=notifications" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
